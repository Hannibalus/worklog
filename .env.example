# Copy to .env and fill in. Do NOT commit .env.

# Flask session secret (generate: python3 -c "import secrets;print(secrets.token_hex(32))")
WORKLOG_SECRET_KEY=change-me-please

# Bootstrap admin: the first superadmin, created automatically on first start
# if this email does not exist yet.
WORKLOG_ADMIN_EMAIL=you@example.com
WORKLOG_ADMIN_PASSWORD=change-me-strong-password
WORKLOG_ADMIN_NAME=Admin

# Optional
# WORKLOG_BRAND_NAME=Work log
# WORKLOG_BRAND_MARK=W
# WORKLOG_INVITE_TTL_HOURS=24
